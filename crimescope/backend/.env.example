# CrimeScope Backend Environment Variables
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# Local Postgres (matches docker-compose.yml defaults).
# Used in dev, and in production if you don't point us at Lakebase.
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crimescope
POSTGRES_USER=crimescope
POSTGRES_PASSWORD=crimescope
DATABASE_URL=postgresql+asyncpg://crimescope:crimescope@localhost:5432/crimescope

# Redis (optional — for future caching)
REDIS_URL=redis://localhost:6379/0

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ---------------------------------------------------------------------------
# OpenAI — free-form analyst chat fallback. Leave empty to disable.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Databricks Model Serving — single-region scoring against the UC champion
# model. When unset, scoring reads from the JSON snapshot.
# ---------------------------------------------------------------------------
DATABRICKS_SERVING_URL=
DATABRICKS_TOKEN=

# ---------------------------------------------------------------------------
# Databricks Genie — natural-language Q&A over Unity Catalog tables.
# When all three are set, the AI Analyst panel routes questions through
# Genie instead of the OpenAI fallback.
#   1. Open the workspace, create a Genie space scoped to
#      `varanasi.default.tract_risk_scores`,
#      `varanasi.default.tract_risk_scores_history`,
#      `varanasi.default.tract_crime_features`,
#      `varanasi.default.tract_acs_population`.
#   2. Copy its space id (UUID after /genie/spaces/ in the URL).
#   3. Mint a workspace PAT and paste it as DATABRICKS_TOKEN.
# ---------------------------------------------------------------------------
DATABRICKS_HOST=
# DATABRICKS_TOKEN is shared with model serving above
DATABRICKS_GENIE_SPACE_ID=

# ---------------------------------------------------------------------------
# Lakebase — Postgres-on-Databricks read store.
# When DATA_STORE_BACKEND=lakebase (or auto with LAKEBASE_URL set), the
# backend reads from Lakebase instead of local Postgres. Same SQL, same UC
# governance, no ETL between training output and API serving.
#   Allowed values: auto | lakebase | postgres | json
# ---------------------------------------------------------------------------
DATA_STORE_BACKEND=auto
LAKEBASE_URL=
