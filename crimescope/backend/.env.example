# CrimeScope Backend Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL (matches docker-compose.yml defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crimescope
POSTGRES_USER=crimescope
POSTGRES_PASSWORD=crimescope
DATABASE_URL=postgresql+asyncpg://crimescope:crimescope@localhost:5432/crimescope

# Redis (optional — for future caching)
REDIS_URL=redis://localhost:6379/0

# OpenAI (required for AI chat — leave empty to use local fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
